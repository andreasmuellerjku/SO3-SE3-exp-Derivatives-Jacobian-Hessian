Cell[CellGroupData[{
Cell[TextData[{
 "Right-trivialized derivative ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["dexp", "X"], TraditionalForm]],ExpressionUUID->
  "73cc12f9-03df-4390-8db6-b504d292e66f"],
 " of the exp map on SE(3)\nThe block-partitioning according to the \
semidirect product SE(3) = SO(3)\:22c9R\.b3 is exploited"
}], "Title",
 CellChangeTimes->{{3.9840242623409977`*^9, 3.9840242702888145`*^9}, {
